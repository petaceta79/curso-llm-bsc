# Copy this file to .env and fill in your values.

# Embeddings endpoint (any OpenAI-compatible API). Default = local Ollama, no key, no cost:
#   ollama serve && ollama pull nomic-embed-text
OPENAI_API_KEY=ollama
EMBED_MODEL=nomic-embed-text
OPENAI_ENDPOINT=http://localhost:11434/v1

# Where the on-disk collection lives (ignored with --memory).
# PERSIST_PATH=./collections-store

# How many nearest chunks a query returns.
# TOP_K=4
