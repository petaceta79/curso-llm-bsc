# Copy this file to .env and fill in your values.

# CHAT model + EMBEDDINGS model. Default = local Ollama, no key, no cost:
#   ollama serve && ollama pull qwen3:1.7b && ollama pull nomic-embed-text
OPENAI_API_KEY=ollama
MODEL=qwen3:1.7b
EMBED_MODEL=nomic-embed-text
OPENAI_ENDPOINT=http://localhost:11434/v1

# Ingestion knobs (knowledge.txt is chunked at startup).
# CHUNK_SIZE=320
# CHUNK_OVERLAP=40

# Retrieval knobs.
# TOP_K=4
# THRESHOLD=0.4

# Unset -> the collection lives in memory, rebuilt each run (identical demo takes).
# Set a path to persist it instead.
# PERSIST_PATH=./collections-store
