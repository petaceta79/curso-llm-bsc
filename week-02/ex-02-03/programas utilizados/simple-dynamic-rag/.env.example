# Copy this file to .env and fill in your values.

# CHAT model (writes the answers) + EMBEDDINGS model (turns text into vectors).
# Default = local Ollama, no key, no cost:
#   ollama serve && ollama pull qwen3:1.7b && ollama pull nomic-embed-text
OPENAI_API_KEY=ollama
MODEL=qwen3:1.7b
EMBED_MODEL=nomic-embed-text
OPENAI_ENDPOINT=http://localhost:11434/v1

# Retrieval knobs.
# COLLECTION=handbook
# PERSIST_PATH=./collections-store
# TOP_K=4
# THRESHOLD=0.4
